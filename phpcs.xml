<?xml version="1.0"?>
<ruleset name="PHP CodeSniffer Configuration">
    <description>PHP CodeSniffer configuration</description>

    <!-- PHP & WP version requirement -->
    <config name="testVersion" value="7.4-" />
    <config name="minimum_supported_wp_version" value="5.0"/>

    <!-- Check PHP version compatibility -->
    <!-- https://github.com/PHPCompatibility/PHPCompatibilityWP -->
	<rule ref="PHPCompatibilityWP"/>

    <!-- WordPress Coding Standards -->
    <!-- https://github.com/WordPress-Coding-Standards/WordPress-Coding-Standards -->
    <rule ref="WordPress">
        <!-- Exclude specific rules -->
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase" />
        <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals" />
        
        <exclude name="Generic.Arrays.DisallowShortArraySyntax" />
        <exclude name="Universal.Arrays.DisallowShortArraySyntax" />

        <exclude name="WordPress.PHP.YodaConditions" />

        <exclude name="Squiz.PHP.CommentedOutCode"/>
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>

        <!-- Template files use single-line ABSPATH guard: if (!defined){exit;} which triggers false Unclosed brace -->
        <exclude name="Squiz.PHP.NonExecutableCode.ReturnNotRequired"/>

        <!-- Allow $order, $type etc as local vars in templates (not truly overriding WP globals) -->
        <exclude name="WordPress.WP.GlobalVariablesOverride.Prohibited"/>

        <!-- date() is used for formatting timestamps, though gmdate() is preferred -->
        <exclude name="WordPress.DateTime.RestrictedFunctions.date_date"/>

        <!-- Plugin bootstrap files legitimately combine a class with helper functions -->
        <exclude name="PSR1.Files.SideEffects.FoundWithSymbols"/>

        <!-- Bootstrap files mix class declarations with global functions by design -->
        <exclude name="Universal.Files.SeparateFunctionsFromOO.Mixed"/>

        <!-- Missing file doc comment is handled at function/class level -->
        <exclude name="Squiz.Commenting.FileComment.Missing"/>

        <!-- Individual method/property docblocks are optional when class docblock exists -->
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
        <exclude name="Squiz.Commenting.VariableComment.Missing"/>

        <!-- Short ternary (?:) is used idiomatically throughout the codebase -->
        <exclude name="Universal.Operators.DisallowShortTernary.Found"/>
    </rule>

    <!-- Exclude non-WordPress sniffs globally -->
    <exclude ref="Squiz.Commenting.FileComment.Missing" />
    <exclude ref="Squiz.Commenting.FileComment.MissingPackageTag" />

    <!-- Suppress false-positive "Unclosed '{'" from single-line ABSPATH exit guard in template files -->
    <exclude ref="Squiz.PHP.NonExecutableCode.Found" />

    <!-- Allow missing file-level docblocks in all PHP files (handled by inline class/function docs) -->
    <exclude ref="Generic.Commenting.DocComment.MissingShort" />

    <!-- Customize the I18n rule; Set text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="subscription" />
            </property>
        </properties>
    </rule>


    <!-- Exclude the following directories -->
    <exclude-pattern>assets/</exclude-pattern>
    <exclude-pattern>build/</exclude-pattern>
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>
</ruleset>